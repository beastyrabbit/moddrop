{
  "name": "stream-canvas",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "portless moddrop-stream-canvas node --watch --env-file=.env --experimental-strip-types src/index.ts",
    "start": "node --env-file=.env --experimental-strip-types src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-force-exit --experimental-strip-types src/*.test.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@hono/node-server": "^1.19.12",
    "@tldraw/sync-core": "^4.5.7",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.11",
    "tldraw": "^4.5.7",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
